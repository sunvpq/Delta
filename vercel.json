{
    "experimentalServices": {
        "frontend": {
            "root": "frontend",
            "routePrefix": "/",
            "framework": "vite",
            "buildCommand": "cd frontend && npm install && npm run build",
            "outputDirectory": "frontend/dist"
        },
        "backend": {
            "root": "backend",
            "routePrefix": "/_/backend",
            "framework": "python"
        }
    }
}